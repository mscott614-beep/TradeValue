# TradeValue — copy to .env.local for Next.js dev
# Production: Secret Manager + apphosting.yaml / Firebase Functions secrets

# --- Gemini (same key material; different env names per surface) ---
GOOGLE_GENAI_API_KEY=
GEMINI_API_KEY=

# --- Cloud Run market-agent (must match Secret Manager AGENT_SERVICE_URL) ---
AGENT_SERVICE_URL=https://market-agent-i2233dwbnq-uk.a.run.app

# --- eBay ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production

# --- Firebase client (from Firebase console → Project settings) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=puckvaluebak-38609945-5e85c
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Cloud Run only (newsletter; not needed for local Next.js) ---
# RESEND_API_KEY=

# --- Cost controls (market-agent Cloud Run) ---
VALUATION_CACHE_TTL_HOURS=24
# ENABLE_PRO_VALUATION_FALLBACK=false

# --- Firebase Functions (scheduledMarketRefresh) ---
MAX_DAILY_REFRESH_ENQUEUES=150
