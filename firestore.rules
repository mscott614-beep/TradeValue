rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rule for the users collection and its sub-collections.
    // A user can read and write to their own documents and sub-collections,
    // but not other users' documents.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    /**
     * @description Manages global market data for cards. This data is intended to be
     *              publicly viewable but managed by a backend process.
     * @path        /market_data/{marketDataId}
     * @allow       (get, list) Any user, including unauthenticated ones, can read market data.
     * @deny        (write) No client can write to the market data collection.
     * @principle   Provides public read access while securing writes for a trusted environment.
     */
    match /market_data/{marketDataId} {
      allow get, list: if true;
      allow write: if false;
    }

    /**
     * @description Manages global auction data. This data is intended to be
     *              publicly viewable but managed by a backend process.
     * @path        /auctions/{auctionId}
     * @allow       (get, list) Any user, including unauthenticated ones, can read auction data.
     * @deny        (write) No client can write to the auction collection.
     * @principle   Provides public read access while securing writes for a trusted environment.
     */
    match /auctions/{auctionId} {
      allow get, list: if true;
      allow write: if false;
    }
  }
}
