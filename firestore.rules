rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    
    // Rules for user-specific data
    match /users/{userId} {
      // Allow the user to read/write their own root document and ALL subcollections recursively
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for global Market Prices (publicly readable)
    match /market_prices/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Rules for Scan Jobs
    match /scan_jobs/{jobId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Compatibility for legacy 'scanJobs'
    match /scanJobs/{jobId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
